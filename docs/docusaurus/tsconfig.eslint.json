{
    "$schema": "https://www.schemastore.org/tsconfig.json",
    "compilerOptions": {
        "allowJs": true,
        "checkJs": true,
        "noEmit": true
    },
    "extends": "./tsconfig.json",
    "include": [
        "typedoc-plugins/**/*.mjs",
        "typedoc-plugins/**/*.mts",
        "typedoc-plugins/**/*.d.mts",
        "typedoc-plugins/escapeMdxMarkdownCore.mjs",
        "typedoc-plugins/hash-to-bang-links-core.mjs",
        "typedoc-plugins/prefix-doc-links-core.mjs"
    ]
}
