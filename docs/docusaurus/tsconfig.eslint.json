{
    "$schema": "https://www.schemastore.org/tsconfig.json",
    "compilerOptions": {
        "allowJs": true,
        "checkJs": true,
        "noEmit": true
    },
    "extends": "./tsconfig.json",
    "include": [
        "typedoc.local.config.mjs",
        "typedoc-plugins/**/*.mjs",
        "typedoc-plugins/**/*.mts",
        "typedoc-plugins/**/*.d.mts",
        "typedoc-plugins/escapeMdxMarkdownCore.mjs",
        "typedoc-plugins/hashToBangLinksCore.mjs",
        "typedoc-plugins/prefixDocLinksCore.mjs"
    ]
}
