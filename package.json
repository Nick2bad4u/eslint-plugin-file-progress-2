{
    "name": "eslint-plugin-file-progress-2",
    "description": "ESLint plugin to print file progress",
    "version": "3.4.3",
    "license": "MIT",
    "author": "Nick2bad4u",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/Nick2bad4u/eslint-plugin-file-progress-2.git"
    },
    "bugs": "https://github.com/Nick2bad4u/eslint-plugin-file-progress-2/issues",
    "homepage": "https://github.com/Nick2bad4u/eslint-plugin-file-progress-2#readme",
    "type": "module",
    "main": "./dist/index.cjs",
    "module": "./dist/index.js",
    "exports": {
        ".": {
            "import": {
                "types": "./dist/index.d.ts",
                "default": "./dist/index.js"
            },
            "require": {
                "types": "./dist/index.d.cts",
                "default": "./dist/index.cjs"
            },
            "default": "./dist/index.js"
        }
    },
    "types": "./dist/index.d.cts",
    "keywords": [
        "eslint",
        "eslintplugin",
        "eslint-plugin",
        "eslint-plugin-file-progress",
        "eslint-plugin-file-progress-2",
        "eslint-progress",
        "progress"
    ],
    "publishConfig": {
        "provenance": true,
        "access": "public"
    },
    "files": [
        "dist/"
    ],
    "contributors": [
        {
            "name": "sibiraj-s",
            "url": "https://github.com/sibiraj-s"
        },
        {
            "name": "Nick2bad4u",
            "url": "https://github.com/Nick2bad4u"
        }
    ],
    "readme": "README.md",
    "prettier": "./.prettierrc.json",
    "displayName": "eslint-plugin-file-progress-2",
    "scripts": {
        "clean": "rimraf dist .cache/tsbuildinfo/tsconfig.build.tsbuildinfo",
        "build": "npm run clean && tsc -p tsconfig.build.json && node scripts/write-cjs-entry.mjs",
        "changelog:release-notes": "node scripts/write-release-notes.mjs",
        "prelint": "npm run build",
        "typecheck": "tsc -p tsconfig.json",
        "lint": "eslint .",
        "test": "tsx --test test/progress.test.ts",
        "docs:install": "npm --prefix docs/docusaurus install",
        "docs:api": "npm --prefix docs/docusaurus run docs:api",
        "docs:build": "npm --prefix docs/docusaurus run build",
        "docs:check": "npm run docs:typecheck && npm run docs:build",
        "docs:clear": "npm --prefix docs/docusaurus run clear",
        "docs:start": "npm --prefix docs/docusaurus run start",
        "docs:typecheck": "npm --prefix docs/docusaurus run typecheck",
        "lint:package-check": "publint && attw --pack .",
        "lint:package-check:strict": "publint && attw --pack . --profile strict --config-path ./.attw.json",
        "lint:package:strict": "npm run lint:package-check:strict",
        "contrib": "all-contributors",
        "contrib:add": "all-contributors add",
        "contrib:check": "all-contributors check",
        "contrib:generate": "all-contributors generate",
        "publint": "publint",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "check": "npm run lint && npm run typecheck && npm run test && npm run format:check",
        "release:check": "npm run check && npm run publint",
        "release:verify": "npm run release:check",
        "prepack": "npm run build"
    },
    "engines": {
        "node": ">=22.0.0"
    },
    "peerDependencies": {
        "eslint": "^9.0.0 || ^10.0.2"
    },
    "dependencies": {
        "nanospinner": "^1.2.2",
        "picocolors": "^1.1.1"
    },
    "devDependencies": {
        "@arethetypeswrong/cli": "^0.18.2",
        "@commitlint/cli": "^20.5.0",
        "@commitlint/config-conventional": "^20.5.0",
        "@types/node": "^25.5.2",
        "@typescript-eslint/eslint-plugin": "^8.58.0",
        "@typescript-eslint/parser": "^8.58.0",
        "all-contributors-cli": "^6.26.1",
        "esbuild": "^0.28.0",
        "eslint": "^10.2.0",
        "eslint-config-pegasus": "^6.0.2",
        "eslint-plugin-eslint-plugin": "^7.3.2",
        "husky": "^9.1.7",
        "is-ci": "^4.1.0",
        "prettier": "^3.8.1",
        "publint": "^0.3.18",
        "rimraf": "^6.1.3",
        "tsx": "^4.21.0",
        "typescript": "^6.0.2"
    }
}
